          "comments": [
            {
              "originalPosition": 4,
              "body": "This should presumably be a subsection of Security Considerations instead of being its own top-level section.",
              "createdAt": "2024-12-04T16:36:02Z",
              "updatedAt": "2024-12-04T16:43:12Z"
            },
            {
              "originalPosition": 7,
              "body": "I think requirement not to mix post-quantum and quantum-vulnerable algorithms is unnecessarily strict and would cause trouble in algorithm transition (this involves long-term keys). I think the proper requirement would be to not use quantum-vulnerable algorithms for messages that require post-quantum security.",
              "createdAt": "2024-12-04T16:42:44Z",
              "updatedAt": "2024-12-04T16:43:12Z"
            }
          ]
        },
